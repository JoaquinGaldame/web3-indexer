{
  "name": "web3-indexer",
  "version": "1.0.0",
  "main": "dist/main.js",
  "imports": {
    "#domain/entities": {
      "development": "./src/domain/entities/index.ts",
      "default": "./dist/domain/entities/index.js"
    },
    "#domain/ports": {
      "development": "./src/domain/ports/index.ts",
      "default": "./dist/domain/ports/index.js"
    },
    "#application/*": {
      "development": "./src/application/*.ts",
      "default": "./dist/application/*.js"
    },
    "#domain/*": {
      "development": "./src/domain/*.ts",
      "default": "./dist/domain/*.js"
    },
    "#infraestructure/blockchain": {
      "development": "./src/infraestructure/blockchain/index.ts",
      "default": "./dist/infraestructure/blockchain/index.js"
    },
    "#infraestructure/db": {
      "development": "./src/infraestructure/db/index.ts",
      "default": "./dist/infraestructure/db/index.js"
    },
    "#infraestructure/db/repositories": {
      "development": "./src/infraestructure/db/repositories/index.ts",
      "default": "./dist/infraestructure/db/repositories/index.js"
    },
    "#infraestructure/*": {
      "development": "./src/infraestructure/*.ts",
      "default": "./dist/infraestructure/*.js"
    },
    "#interfaces/*": {
      "development": "./src/interfaces/*.ts",
      "default": "./dist/interfaces/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --conditions=development --watch --import tsx ./src/main.ts",
    "worker": "node --conditions=development --watch --import tsx ./src/interfaces/workers/sync.worker.ts",
    "start": "node dist/main.js",
    "start:worker": "node dist/interfaces/workers/sync.worker.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
